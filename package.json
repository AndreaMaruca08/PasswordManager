{
  "name": "passwordmanager",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "clean": "rm -rf dist node_modules package-lock.json",
    "rebuild": "npm run clean && npm install && npm run build",
    "docker:rebuild": "npm run rebuild && docker compose down -v && docker compose build --no-cache && docker compose up"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.4.2",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pug": "3.0.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "7.4.2",
    "typescript": "^5.9.3"
  }
}
